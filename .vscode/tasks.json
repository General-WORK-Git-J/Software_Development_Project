
{ // uncomment for cl.exe build task
    "tasks": [
        {
            "label": "C/C++: cl.exe build active file",
            "type": "process",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/nologo",
                "/Fe",
                "${workspaceFolder}\\Software_Development_Project.exe",
                "${workspaceFolder}\\main.cpp",
                "${workspaceFolder}\\admin.cpp",
                "${workspaceFolder}\\captain.cpp",
                "${workspaceFolder}\\hero.cpp",
                "${workspaceFolder}\\team.cpp",
                "${workspaceFolder}\\user_system.cpp",
                "${workspaceFolder}\\team_system.cpp",
                "${workspaceFolder}\\villain.cpp"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$msCompile"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Invoke MSVC cl.exe to compile and link project sources"
        }
    ],
    "version": "2.0.0"
}