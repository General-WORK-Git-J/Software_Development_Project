
{
    "tasks": [
        {
            "label": "C/C++: cl.exe build active file",
            "type": "process",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/nologo",
                "/Fe:${workspaceFolder}\\Software_Development_Project.exe",
                "${workspaceFolder}\\CPP_Files\\main.cpp",
                "${workspaceFolder}\\CPP_Files\\admin.cpp",
                "${workspaceFolder}\\CPP_Files\\captain.cpp",
                "${workspaceFolder}\\CPP_Files\\hero.cpp",
                "${workspaceFolder}\\CPP_Files\\team.cpp",
                "${workspaceFolder}\\CPP_Files\\team_reader.cpp",
                "${workspaceFolder}\\CPP_Files\\user_system.cpp",
                "${workspaceFolder}\\CPP_Files\\team_system.cpp",
                "${workspaceFolder}\\CPP_Files\\villain.cpp"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$msCompile"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Invoke MSVC cl.exe to compile and link project sources"
        }
    ],
    "version": "2.0.0"
}